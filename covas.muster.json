{
  "schemaVersion": 1,
  "app": "COVAS\u002B\u002B",
  "tests": [
    {
      "id": "fresh-install-native-wizard",
      "title": "Fresh install shows the first-run wizard IN THE NATIVE WINDOW",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "NET",
        "HW"
      ],
      "requires": "Empty user-data dir: delete %APPDATA%\\COVAS\u002B\u002B (back it up first if it has your keys). Launch the packaged app via dist\\COVAS\u002B\u002B\\COVAS\u002B\u002B.exe (or \u0060python run_covas_app.py\u0060).",
      "expected": "The setup wizard renders inside the COVAS\u002B\u002B native PyWebView window. No browser (Edge/Chrome/etc.) opens at any point.",
      "steps": [
        {
          "id": "s1",
          "text": "Confirm %APPDATA%\\COVAS\u002B\u002B is absent/empty, then launch COVAS\u002B\u002B.exe (or run_covas_app.py)."
        },
        {
          "id": "s2",
          "text": "A native window titled COVAS\u002B\u002B appears showing the first-run setup page (API keys / speech model / mic)."
        },
        {
          "id": "s3",
          "text": "No browser tab or window opens \u2014 the wizard is ONLY in the native window."
        }
      ]
    },
    {
      "id": "wizard-to-panel-handoff",
      "title": "Finishing setup swaps the SAME window to the control panel (no browser)",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "NET",
        "HW"
      ],
      "requires": "Continue from fresh-install-native-wizard, in the native window on the wizard page.",
      "expected": "After entering the Anthropic key (ElevenLabs optional), downloading the STT model, and picking a mic, clicking Launch turns the SAME native window into the control panel (status light IDLE), no browser. The finish message must say it\u0027s switching to the control panel and must NOT tell you to close the window/tab \u2014 closing the single native window would QUIT the app.",
      "steps": [
        {
          "id": "s1",
          "text": "Enter your Anthropic API key (and optionally ElevenLabs) and save."
        },
        {
          "id": "s2",
          "text": "Trigger the speech-model download; wait for it to report ready."
        },
        {
          "id": "s3",
          "text": "Pick a microphone."
        },
        {
          "id": "s4",
          "text": "Click \u0027Launch COVAS\u002B\u002B\u0027. Read the finish message: it should say COVAS\u002B\u002B is starting / switching to the control panel \u2014 NOT \u0027you can close this tab\u0027."
        },
        {
          "id": "s5",
          "text": "WITHOUT closing anything, the same window switches to the control panel (status light IDLE) within a few seconds. Do NOT close the window \u2014 that quits the app."
        }
      ]
    },
    {
      "id": "already-configured-skips-wizard",
      "title": "Relaunch on a configured install goes straight to the panel",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "HW"
      ],
      "requires": "Completed setup at least once (keys \u002B STT model present in %APPDATA%\\COVAS\u002B\u002B).",
      "expected": "Launching COVAS\u002B\u002B.exe (or run_covas_app.py) opens the native window directly on the control panel \u2014 no wizard, no browser.",
      "steps": [
        {
          "id": "s1",
          "text": "Close COVAS\u002B\u002B if open, then relaunch it."
        },
        {
          "id": "s2",
          "text": "The native window opens directly on the control panel (IDLE); the wizard does not appear."
        }
      ]
    },
    {
      "id": "bail-mid-wizard-quits-clean",
      "title": "Closing the window during the wizard quits cleanly",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "HW"
      ],
      "requires": "Fresh/empty user-data dir so the wizard shows. Launch via COVAS\u002B\u002B.exe (or run_covas_app.py).",
      "expected": "Closing the native window while still on the wizard exits the process fully \u2014 no orphaned COVAS\u002B\u002B process, and the port (127.0.0.1:8765) is free for an immediate relaunch.",
      "steps": [
        {
          "id": "s1",
          "text": "With the wizard showing, close the native window (X) before finishing setup."
        },
        {
          "id": "s2",
          "text": "Confirm no COVAS\u002B\u002B process lingers (Task Manager) \u2014 the app quit."
        },
        {
          "id": "s3",
          "text": "Relaunch immediately; it starts again without a \u0027port in use\u0027/\u0027address already in use\u0027 error."
        }
      ]
    },
    {
      "id": "native-quit-controls",
      "title": "Ctrl\u002BAlt\u002BQ and window-close both quit the running app",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "HW"
      ],
      "requires": "App running on the control panel (post-setup).",
      "expected": "Pressing Ctrl\u002BAlt\u002BQ closes the window and exits the process; separately, closing the window with X also exits. No lingering process either way.",
      "steps": [
        {
          "id": "s1",
          "text": "With the panel showing, press Ctrl\u002BAlt\u002BQ \u2014 the window closes and the process exits."
        },
        {
          "id": "s2",
          "text": "Relaunch, then close the window with the X button \u2014 the process also exits (no tray, no background loop)."
        }
      ]
    },
    {
      "id": "browser-path-unchanged",
      "title": "Source browser entry (run_covas_ui.py) still opens the wizard in the browser",
      "section": "I9. Native first-run wizard",
      "tags": [
        "GUI",
        "NET"
      ],
      "requires": "Empty user-data dir. Run the BROWSER entry from source: \u0060python run_covas_ui.py\u0060.",
      "expected": "run_covas_ui.py is unchanged by I9: on a fresh install it serves the wizard and opens it in the DEFAULT BROWSER (not a native window), then the browser control panel once configured.",
      "steps": [
        {
          "id": "s1",
          "text": "With an empty user-data dir, run \u0060python run_covas_ui.py\u0060."
        },
        {
          "id": "s2",
          "text": "The default browser opens http://127.0.0.1:8765 showing the setup wizard."
        },
        {
          "id": "s3",
          "text": "Finish setup; the browser continues to the control panel (IDLE)."
        }
      ]
    },
    {
      "id": "frozen-selftest",
      "title": "Frozen build passes the headless self-test",
      "section": "I9. Native first-run wizard",
      "tags": [
        "PKG"
      ],
      "requires": "Rebuild the frozen app: \u0060.\\build.ps1 -SelfTest\u0060.",
      "expected": "PyInstaller produces dist\\COVAS\u002B\u002B\\COVAS\u002B\u002B.exe and \u0060COVAS\u002B\u002B.exe --selftest\u0060 prints \u0027SELFTEST OK ...\u0027 and exits 0 (build.ps1 reports \u0027Self-test passed\u0027).",
      "steps": [
        {
          "id": "s1",
          "text": "Run \u0060.\\build.ps1 -SelfTest\u0060 from the repo root."
        },
        {
          "id": "s2",
          "text": "Build completes and the frozen self-test passes (exit 0)."
        }
      ]
    },
    {
      "id": "version-by-voice",
      "title": "\u0022What version are you?\u0022 reports the running version",
      "section": "I7. Version by voice",
      "tags": [
        "HW"
      ],
      "requires": "App running (native window, browser UI, or headless). Know the expected version from \u0060covas/__version__.py\u0060 (currently 0.1.0).",
      "expected": "COVAS speaks the running version, e.g. \u0022I\u0027m running COVAS\u002B\u002B version 0.1.0.\u0022, matching covas/__version__.py exactly.",
      "steps": [
        {
          "id": "s1",
          "text": "Hold \u0060[\u0060, say \u0022What version are you?\u0022, release."
        },
        {
          "id": "s2",
          "text": "The spoken reply names the version and it matches the string in \u0060covas/__version__.py\u0060."
        },
        {
          "id": "s3",
          "text": "Try a variant (\u0022which build is this?\u0022) \u2192 still reports the same version."
        }
      ]
    },
    {
      "id": "check-updates-by-voice-is-ui-only",
      "title": "\u0022Check for updates\u0022 by voice does NOT update \u2014 points to the panel",
      "section": "I7. Version by voice",
      "tags": [
        "HW"
      ],
      "requires": "App running.",
      "expected": "Asking to check for / install an update by VOICE does not trigger any download or relaunch; COVAS says updates are done from the control panel\u0027s update banner. (Updating stays a UI action \u2014 INSTALLER_DESIGN decision #5.)",
      "steps": [
        {
          "id": "s1",
          "text": "Hold \u0060[\u0060, say \u0022Check for updates.\u0022, release."
        },
        {
          "id": "s2",
          "text": "COVAS does NOT download or relaunch anything; it points you at the control panel\u0027s update banner instead."
        }
      ]
    },
    {
      "id": "cues-shipped-defaults-play",
      "title": "Shipped default cues play out of the box (no user cues)",
      "section": "I8. Sound cues (drop-in folders)",
      "tags": [
        "HW"
      ],
      "requires": "No user cue overrides present: \u0060\u003Cdata dir\u003E\\sounds\\listen\\\u0060 etc. are empty or absent (source run: \u0060.\\sounds\\\u0060; packaged: \u0060%APPDATA%\\COVAS\u002B\u002B\\sounds\\\u0060). App running with speakers/headset.",
      "expected": "You hear the shipped ORIGINAL cues at each stage \u2014 a \u0060listen\u0060 chirp on press, a \u0060processing\u0060 tick while it works, a \u0060completed\u0060 cue right before speech, and a \u0060failure\u0060 cue on no-speech. None are silent.",
      "steps": [
        {
          "id": "s1",
          "text": "Hold \u0060[\u0060 \u2192 you hear the \u0060listen\u0060 cue immediately (before speaking)."
        },
        {
          "id": "s2",
          "text": "Say a short prompt and release \u2192 you hear the \u0060processing\u0060 cue."
        },
        {
          "id": "s3",
          "text": "Just before the spoken answer you hear the \u0060completed\u0060 cue."
        },
        {
          "id": "s4",
          "text": "Press and release WITHOUT speaking \u2192 you hear the \u0060failure\u0060 cue; the log notes no speech detected."
        }
      ]
    },
    {
      "id": "cues-open-folder-button",
      "title": "\u0027Open cues folder\u0027 opens the sounds dir with the per-type skeleton",
      "section": "I8. Sound cues (drop-in folders)",
      "tags": [
        "GUI",
        "FILE"
      ],
      "requires": "Control panel open (native window or browser).",
      "expected": "Clicking Open cues folder opens the OS file manager on \u0060\u003Cdata dir\u003E\\sounds\\\u0060 containing \u0060listen\\ processing\\ completed\\ failure\\\u0060 subfolders, each with a \u0060README.txt\u0060. The button shows \u0027opened\u0027.",
      "steps": [
        {
          "id": "s1",
          "text": "In the first (config) card, click \u0060OPEN CUES FOLDER\u0060."
        },
        {
          "id": "s2",
          "text": "Explorer opens \u0060\u003Cdata dir\u003E\\sounds\\\u0060 (source run: repo \u0060.\\sounds\\\u0060; packaged: \u0060%APPDATA%\\COVAS\u002B\u002B\\sounds\\\u0060)."
        },
        {
          "id": "s3",
          "text": "It contains \u0060listen\u0060, \u0060processing\u0060, \u0060completed\u0060, \u0060failure\u0060 folders, each with a README.txt explaining drop-in cues."
        }
      ]
    },
    {
      "id": "cues-override-replaces-and-rotates",
      "title": "User cues in a type folder replace the default and rotate randomly",
      "section": "I8. Sound cues (drop-in folders)",
      "tags": [
        "HW",
        "FILE"
      ],
      "requires": "Access to \u0060\u003Cdata dir\u003E\\sounds\\listen\\\u0060 (use Open cues folder). Have 2-3 distinct short \u0060.wav\u0060 files to drop in.",
      "expected": "With \u003E=1 file in \u0060sounds\\listen\\\u0060, the press-to-talk cue plays YOUR files (the shipped default is no longer heard) and VARIES across presses (random rotation over any count).",
      "steps": [
        {
          "id": "s1",
          "text": "Drop 2-3 distinct \u0060.wav\u0060 files into \u0060sounds\\listen\\\u0060, then restart COVAS\u002B\u002B."
        },
        {
          "id": "s2",
          "text": "Press to talk several times \u2192 the \u0060listen\u0060 cue is now clearly YOUR audio, not the shipped chirp."
        },
        {
          "id": "s3",
          "text": "Across presses the cue VARIES (a random file each time)."
        }
      ]
    },
    {
      "id": "cues-empty-folder-falls-back",
      "title": "Emptying a type folder falls back to the shipped default",
      "section": "I8. Sound cues (drop-in folders)",
      "tags": [
        "HW",
        "FILE"
      ],
      "requires": "Continue from cues-override-replaces-and-rotates (your files are in \u0060sounds\\listen\\\u0060).",
      "expected": "Remove your files from \u0060sounds\\listen\\\u0060 and restart \u2192 the press-to-talk cue is the SHIPPED default \u0060listen\u0060 chirp again (fallback works).",
      "steps": [
        {
          "id": "s1",
          "text": "Delete the files you added to \u0060sounds\\listen\\\u0060 (leave the folder empty), then restart COVAS\u002B\u002B."
        },
        {
          "id": "s2",
          "text": "Press to talk \u2192 you hear the shipped default \u0060listen\u0060 cue, not your removed audio."
        }
      ]
    },
    {
      "id": "cues-interdiction-sting-default",
      "title": "Interdiction plays the shipped original sting when no user sting is set",
      "section": "I8. Sound cues (drop-in folders)",
      "tags": [
        "HW",
        "GAME"
      ],
      "requires": "\u0060[audio.interdiction].enabled\u0060 (and the audio layer) ON, with NO user interdiction sting configured or dropped in. Elite Dangerous running; trigger (or wait for) an Interdiction / UnderAttack event.",
      "expected": "On an interdiction, the ALERT sting is the shipped ORIGINAL sting (audible), not silence \u2014 the bundled default fills in when the user supplies none.",
      "steps": [
        {
          "id": "s1",
          "text": "With interdiction enabled and no custom sting, get interdicted (or pull a rebuy-safe NPC interdiction)."
        },
        {
          "id": "s2",
          "text": "You hear an alert sting at the start of the interdiction cue (followed by the threat line)."
        }
      ]
    }
  ],

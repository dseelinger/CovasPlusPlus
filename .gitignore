# ============================================================================
#  COVAS++ .gitignore  —  PUBLIC REPO. Keep secrets and personal data OUT.
#  NOTE: git only treats '#' as a comment at the START of a line, never inline.
#  So every comment here lives on its own line, above the pattern it describes.
# ============================================================================

# --- Secrets (NEVER commit) ---
ElevenLabsAPIKey.txt
AnthropicAPIKey.txt
AzureSpeechKey.txt
OpenAIAPIKey.txt
CartesiaAPIKey.txt
GeminiAPIKey.txt
InaraAPIKey.txt
*.key
.env
.env.*

# --- Personal / per-user data ---
# private character + campaign (use personality.example.txt instead)
personality.txt
# campaign = the Commander's personal facts (N7), kept separate from the shareable persona
campaign.txt
# custom personas saved from the Personality tab (may contain personal flavor)
personalities/custom/
# auto-generated per-account persona->voice pairing cache (issue #96): built from YOUR
# ElevenLabs voice list, recomputed when personas or that list change — never committed.
personalities/voice_pairings.json
# local UI / runtime settings
overrides.json
# per-session conversation transcripts (personal)
logs/
# personal game checklist
ultimate_checklist.md
# crew roster (issue #70) — the Commander's characters + persona text (personal)
crew.json
# hired NPC-crew registry (issue #125) — pilot names harvested from the journal (personal)
npc_crew.json
# owned-ships registry (issue #134) — the Commander's fleet identity, folded from Shipyard
# events + manual CRUD (ship names/idents are personal). Journal-derived; never committed.
owned_ships.json
# per-ship loadout + engineering memory (issue #135) — each owned ship's modules + applied
# engineering, keyed by ShipID (personal build data). Journal-derived; never committed.
ship_loadouts.json
# auto-generated crew best-fit-voice pairing cache (issue #124) — mirrors the persona cache above
# but keyed to the crew roster, so a roster edit never busts the shipped-persona cache.
crew_voice_pairings.json
# persistent memory (issue #59) — private, human-readable facts about the Commander.
# Anchored to the repo root so it doesn't also swallow docs/memory.md etc.
/memory/
# custom macros (issue #50) — Commander-authored macros; their content is personal.
custom_macros.jsonl

# --- Transient / local working files (scratchpad, not for the repo) ---
# scratchpad for in-progress / one-off bug-fix prompts
Bug_prompts.md

# --- License-uncertain / regenerable assets ---
# sound cues — supply your own; may be copyrighted
sounds/
# cached generated TTS output
voicelines/
# ambient music tracks (C7) — supply your own; rights uncertain
music/
# drop-in content (C11) — user assets + line pools; skeleton READMEs are generated at runtime.
# Anchored to the repo root (leading slash) so these don't also swallow docs/audio/ etc.
/audio/
/content/
# Piper voice models (large binaries)
*.onnx
*.onnx.json

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# --- Docs site (MkDocs build output; source lives in docs/) ---
site/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Manual-test (Muster): suites AND run scratch are local-only, never tracked.
#     The runner writes results/status into the *.muster.json files, so they're
#     working state, not source — kept out of the repo. ---
.muster/
*.muster.json

# Local journal-injection scratch for manual event testing (see inject_event notes) — never tracked.
_fakejournal/

# Local scratch folder for untracked working files — never tracked.
ignored/
